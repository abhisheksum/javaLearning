public class Main
{
	public static void main(String[] args) {
	    int [] arr = {1,9,2,4,5,6,7};
	    int j = 0;
	    int i = arr.length - 1;
	    
	    while(j < i){
	            int temp = arr[i];
	            arr[i] = arr[j];
	            arr[j] = temp;
	            j++;
	            i--;
	        }
	    for(int k = 0; k < arr.length; k++){
	        System.out.print(arr[k] + " ");
	    }
		System.out.println();
	    
	}
}

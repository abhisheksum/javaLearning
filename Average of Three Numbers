import java.util.Scanner;

public class AverageProgram {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int A = sc.nextInt();
        int B = sc.nextInt();
        int C = sc.nextInt();

        float avg = (A + B + C) / 3.0f;
        System.out.println(avg);
    }
}
